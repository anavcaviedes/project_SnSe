&CONTROL
  calculation  = "relax",
  prefix       = "SnSe_pnma",
  pseudo_dir   = "../pseudo",
  outdir       = "./tmp",
  restart_mode = "from_scratch",
  verbosity    = "high",
  tprnfor      = .true.,
/

&SYSTEM
  ibrav       = 0,	
  A           = 4.5555, 
  nat         = 4,
  ntyp        = 2,
  ecutwfc     = 30,	 
  ecutrho     = 300, 
  occupations = 'fixed',
  vdw_corr = 'grimme-d3'
/

&ELECTRONS
  conv_thr    = 1.D-8,
  mixing_beta = 0.7D0,
/

&IONS
  ion_dynamics = 'bfgs'
/

